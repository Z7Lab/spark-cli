# Runtime model catalog — the operator's own editable list, seeded from
# templates/models.example.json on first use.
templates/models.json

# Python bytecode
__pycache__/
*.py[cod]

# Editor / OS
.DS_Store
*.swp
*.swo
*~

# dispatcher sandbox artifacts
.mcp.json
.dispatcher/
.claude/.sandbox-exit-code
.claude/.sandbox-status.json
.codex/.sandbox-status.json

# Sensitive-file guards — prevent accidental commit of secrets
*.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.keystore
secrets/
credentials/
config.local.*

# Runtime engine catalog — seeded from templates/engines.example.json on first use.
templates/engines.json

# Captured model reports (spark llm bench/probe --save). Your own runs stay
# local; only the project's reference set under reports/reference/ is tracked.
# Want your own results in git? Delete the next two lines or commit a subdir.
/reports/*
!/reports/reference/
