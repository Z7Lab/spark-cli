#!/usr/bin/env python3
"""spark — DGX Spark management CLI.

Manages model serving, downloads, image/video generation, transcription, and
playbooks on a remote DGX Spark over SSH.

This entry point is intentionally thin: every command is defined ONCE in a
manifest under `commands/<domain>/<verb>.md` (a fenced ```spec JSON block + a
markdown help body). That single definition drives CLI routing, the three-level
help hierarchy, and MCP-ready tool schemas. The work lives in
`lib/handlers/<domain>.py`; this file only loads manifests, routes argv, parses
it against the matched spec, calls the handler, and renders the result.

Config: ~/.config/spark.json  (create with: spark init)
"""

from __future__ import annotations

import sys
from pathlib import Path

# Make the bundled library importable (no-install, PATH-based single entry point).
sys.path.insert(0, str(Path(__file__).resolve().parent.parent / "lib"))

import cliparse
import manifest
import handlers
from sparkcore import load_config, bold, dim, cyan, red, warn, CONFIG_PATH

_COLORS = {"bold": bold, "dim": dim, "cyan": cyan}
_HELP_FLAGS = ("--help", "-h")

_BANNER = """spark — DGX Spark management CLI.

Manages model serving, downloads, image/video generation, transcription, and
playbooks on a remote DGX Spark over SSH."""


def _top_help(routing: dict, cfg: dict):
    print(_BANNER)
    print()
    print(bold("Commands:"))
    width = max((len(d) for d in routing), default=0) + 2
    for domain in sorted(routing):
        group = routing[domain]
        if manifest.is_grouped(group):
            subs = ", ".join(sorted(s for s in group if s))
            desc = dim(subs)
        else:
            desc = group[None]["spec"].get("summary", "")
        print(f"  {cyan(f'{domain:<{width}}')} {desc}")
    print()
    cfg_status = str(CONFIG_PATH) if CONFIG_PATH.exists() else warn(f"{CONFIG_PATH} (not found — run: spark init)")
    print(f"  Config: {cfg_status}")
    print(f"  Host:   {cyan(cfg['dgx_host'])}")
    print(dim("\n  Run 'spark <command> --help' (or 'spark <domain> <sub> --help') for details."))


def _schema_cmd(entries: list, argv: list):
    """`spark _schema [name]` — print MCP tool schema(s) from the manifests.

    Proves the single manifest source can feed an MCP server: the JSON Schema
    here is exactly what a tool registration would use. Server itself is a
    separate, deferred surface (see the plan's deferred follow-up).
    """
    import json
    want = argv[0] if argv else None
    out = []
    for e in entries:
        spec = e["spec"]
        if want and want not in (manifest.canonical_name(spec), manifest.tool_name(spec)):
            continue
        out.append(manifest.to_json_schema(spec))
    if want and not out:
        print(red(f"No command matching '{want}'."), file=sys.stderr)
        sys.exit(1)
    print(json.dumps(out[0] if (want and len(out) == 1) else out, indent=2))


def main():
    argv = sys.argv[1:]
    cfg = load_config()
    entries = manifest.discover()
    routing = manifest.build_routing(entries)

    if not argv or argv[0] in _HELP_FLAGS:
        _top_help(routing, cfg)
        return

    token = argv[0]

    if token == "_schema":
        _schema_cmd(entries, argv[1:])
        return

    if token not in routing:
        print(red(f"Unknown command: {token}"))
        print(f"Run {cyan('spark --help')} for available commands.")
        sys.exit(1)

    group = routing[token]

    # Resolve the target command entry and the argv tail to parse.
    if manifest.is_grouped(group):
        default = manifest.default_subcommand(group)
        if len(argv) < 2:
            # Bare `spark <domain>`: run its default sub if one is declared,
            # otherwise list the subcommands.
            if default is None:
                print(manifest.domain_help(token, group, _COLORS))
                return
            entry = group[default]
            tail = []
        elif argv[1] in _HELP_FLAGS:
            print(manifest.domain_help(token, group, _COLORS))
            return
        elif argv[1] in group:
            entry = group[argv[1]]
            tail = argv[2:]
        else:
            print(red(f"Unknown {token} subcommand: {argv[1]}"))
            print(f"  Run {cyan(f'spark {token} --help')} for usage.")
            sys.exit(1)
    else:
        entry = group[None]
        tail = argv[1:]

    if any(t in _HELP_FLAGS for t in tail):
        print(manifest.command_help(entry, _COLORS))
        return

    # One place argv is interpreted → typed params → the handler.
    try:
        params = cliparse.parse(entry["spec"].get("params", []), tail)
    except cliparse.ParseError as e:
        spec = entry["spec"]
        name = "spark " + spec["domain"] + (" " + spec["subcommand"] if spec.get("subcommand") else "")
        print(red(f"{name}: {e}"))
        print(f"  Run {cyan(name + ' --help')} for usage.")
        sys.exit(1)

    fn = handlers.get(entry["spec"]["handler"])
    # Handlers render their own operator-facing output AND return a structured
    # result dict. The CLI ignores the return value here; a future MCP wrapper
    # reuses the same handler with stdout redirected and SystemExit caught,
    # consuming the structured result as tool output.
    fn(params, cfg)


if __name__ == "__main__":
    main()
